;; The `babashka/fs` and `babashka/process` deps are the de-facto JVM
;; Clojure standard for filesystem and subprocess work — borkdude
;; libraries that happen to live under the babashka org but have no
;; runtime dependency on bb. We use them on JVM, not bb.
{:paths ["src" "resources"]
 :deps  {org.clojure/clojure              {:mvn/version "1.12.0"}
         org.clojure/core.async           {:mvn/version "1.6.681"}
         org.clojure/tools.cli            {:mvn/version "1.1.230"}
         babashka/fs                      {:mvn/version "0.5.33"}
         babashka/process                 {:mvn/version "0.5.22"}
         cheshire/cheshire                {:mvn/version "5.13.0"}
         clj-commons/clj-yaml             {:mvn/version "1.0.29"}
         hiccup/hiccup                    {:mvn/version "2.0.0-RC3"}
         http-kit/http-kit                {:mvn/version "2.8.0"}
         nrepl/nrepl                      {:mvn/version "1.3.0"}
         com.github.seancorfield/honeysql {:mvn/version "2.6.1126"}
         com.github.seancorfield/next.jdbc {:mvn/version "1.3.939"}
         org.xerial/sqlite-jdbc           {:mvn/version "3.46.1.3"}}

 :aliases
 {:server
  {:main-opts ["-m" "cli.cch" "serve"]}

  :cli
  {:main-opts ["-m" "cli.cch"]}

  :test
  {:extra-paths ["test"]
   :extra-deps  {io.github.cognitect-labs/test-runner
                 {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                 hato/hato {:mvn/version "1.0.0"}}
   :exec-fn     cognitect.test-runner.api/test
   :exec-args   {:dirs ["test"]}}

  :build
  {:deps       {io.github.clojure/tools.build {:mvn/version "0.10.6"}}
   :ns-default build}}}
