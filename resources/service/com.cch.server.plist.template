<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.cch.server</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/env</string>
    <string>bb</string>
    <string>-cp</string>
    <string>{{HOME}}/.local/share/cch/repo/src:{{HOME}}/.local/share/cch/repo/resources</string>
    <string>-m</string>
    <string>cli.cch</string>
    <string>serve</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>{{HOME}}/.local/share/cch/serve.log</string>
  <key>StandardErrorPath</key>
  <string>{{HOME}}/.local/share/cch/serve.log</string>
</dict>
</plist>
