<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.cch.server</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>{{PATH}}</string>
  </dict>
  <key>WorkingDirectory</key>
  <string>{{HOME}}/.local/share/cch/repo</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/env</string>
    <string>clj</string>
    <string>-M:server</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>{{HOME}}/.local/share/cch/serve.log</string>
  <key>StandardErrorPath</key>
  <string>{{HOME}}/.local/share/cch/serve.log</string>
</dict>
</plist>
