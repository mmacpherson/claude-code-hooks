[Unit]
Description=cch HTTP dispatcher + dashboard (jlink runtime)
Documentation=https://github.com/mmacpherson/claude-code-hooks
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/.local/share/cch/repo
ExecStart=%h/.local/share/cch/runtime/bin/cch serve
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
