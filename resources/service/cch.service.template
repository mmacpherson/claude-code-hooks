[Unit]
Description=cch HTTP dispatcher + dashboard
Documentation=https://github.com/mmacpherson/claude-code-hooks
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/.local/share/cch/repo
ExecStart=/usr/bin/env clj -M:server
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
